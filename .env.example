# ── Local dev (full server: Next.js + Socket.IO) ──────────────────────────────
PORT=3000
HOSTNAME=localhost
NODE_ENV=development

# ── Production: Socket.IO server (Railway / Render / Fly.io) ─────────────────
# URL of the standalone Socket.IO server — set this on Vercel
NEXT_PUBLIC_SOCKET_URL=https://your-railway-app.up.railway.app

# CORS: comma-separated list of allowed origins for the Socket.IO server
# Example: https://tropicam-app.vercel.app,https://tropicam.fr
ALLOWED_ORIGINS=https://your-vercel-app.vercel.app

# ── TURN server (optional but recommended behind restrictive NATs) ─────────────
# Free TURN: https://www.metered.ca/tools/openrelay/
NEXT_PUBLIC_TURN_URL=
NEXT_PUBLIC_TURN_USERNAME=
NEXT_PUBLIC_TURN_CREDENTIAL=
